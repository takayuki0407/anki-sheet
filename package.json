{
  "name": "anki-sheet",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Digital red-sheet + Anki-style SRS for colored-answer study PDFs (client-side, offline).",
  "scripts": {
    "copy-assets": "node scripts/copy-pdfjs-assets.mjs",
    "postinstall": "node scripts/copy-pdfjs-assets.mjs",
    "predev": "node scripts/copy-pdfjs-assets.mjs",
    "dev": "vite",
    "prebuild": "node scripts/copy-pdfjs-assets.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "colord": "2.9.3",
    "dexie": "4.4.3",
    "dexie-react-hooks": "4.4.0",
    "pdfjs-dist": "6.0.227",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "ts-fsrs": "5.4.1",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "6.0.2",
    "puppeteer-core": "^25.1.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "4.1.8"
  }
}
